{
  "rewrites": [
    { "source": "/api/search", "destination": "/api/search" },
    { "source": "/api/enrich", "destination": "/api/enrich" },
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/test", "destination": "/api/test" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/search.js": { "memory": 1024, "maxDuration": 30 },
    "api/enrich.js": { "memory": 1024, "maxDuration": 30 },
    "api/generate.js": { "memory": 1024, "maxDuration": 30 },
    "api/test.js": { "memory": 1024, "maxDuration": 10 }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
